{
    "version": 2,
    "builds": [
      {
        "src": "/built/server.js",
        "use": "@vercel/node"
      },
      {
        "src": "/dist/frontend/browser/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
          {
            "src": "/(.*)",
            "dest": "/built/server.js"
          }
           
    ]
  }
  